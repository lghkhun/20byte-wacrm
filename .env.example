MYSQL_PORT=3307
REDIS_PORT=6379

DATABASE_URL="mysql://root:password@localhost:3307/20byte"
REDIS_URL="redis://localhost:6379"

NEXTAUTH_SECRET="replace-with-a-random-secret"
NEXTAUTH_URL="http://localhost:3000"
APP_URL="http://localhost:3000"
RESEND_API_KEY="re_xxxxxxxxx"
RESEND_FROM_EMAIL="20byte <noreply@mailer.20byte.com>"
RESEND_REPLY_TO_EMAIL="support@20byte.com"

ABLY_API_KEY="ably-key-placeholder"
SHORTLINK_BASE_URL="https://wa.yourdomain.com"

R2_ACCOUNT_ID="r2-account-id"
R2_ACCESS_KEY_ID="r2-access-key"
R2_SECRET_ACCESS_KEY="r2-secret"
R2_BUCKET="20byte-media"
R2_PUBLIC_URL="https://example.r2.dev"

WHATSAPP_MOCK_MODE="true"

PAKASIR_PROJECT_SLUG="your-pakasir-project-slug"
PAKASIR_API_KEY="your-pakasir-api-key"
PAKASIR_BASE_URL="https://app.pakasir.com"
PAKASIR_DEFAULT_METHOD="qris"
PAKASIR_WEBHOOK_PATH="/api/billing/webhooks/pakasir"
PAKASIR_WEBHOOK_TOKEN="replace-with-random-webhook-token"

LOUVIN_API_KEY="your-louvin-api-key"
LOUVIN_BASE_URL="https://api.louvin.dev"
LOUVIN_DEFAULT_METHOD="qris"
LOUVIN_WEBHOOK_PATH="/api/billing/webhooks/louvin"
LOUVIN_WEBHOOK_TOKEN="replace-with-random-webhook-token"

SUPERADMIN_EMAILS="owner@yourdomain.com,admin@yourdomain.com"

# Set to "true" to disable billing/subscription enforcement (for self-hosters)
# When enabled, all features work without payment gateway keys
DISABLE_BILLING="false"
