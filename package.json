{
  "name": "20byte",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "up": "npm run docker:up",
    "down": "npm run docker:down",
    "restart": "npm run docker:restart",
    "rebuild": "npm run docker:rebuild",
    "logs": "npm run docker:logs",
    "ps": "npm run docker:ps",
    "db:migrate": "node scripts/run-with-local-env.mjs npx prisma migrate deploy",
    "db:migrate:vps": "node scripts/check-vps-tunnel.mjs && npm run db:migrate",
    "db:push": "node scripts/run-with-local-env.mjs npx prisma db push",
    "db:studio": "node scripts/run-with-local-env.mjs npx prisma studio --hostname 0.0.0.0 --port 5555",
    "dev": "node scripts/run-with-local-env.mjs node scripts/dev-server.mjs",
    "docs:dev": "npm --prefix developer-docs run dev",
    "docs:build": "npm --prefix developer-docs run build",
    "docs:serve": "npm --prefix developer-docs run serve",
    "docker:up": "docker compose -f docker-compose.yml -f docker-compose.dev.yml up -d",
    "docker:down": "docker compose -f docker-compose.yml -f docker-compose.dev.yml down",
    "docker:restart": "docker compose -f docker-compose.yml -f docker-compose.dev.yml down && docker compose -f docker-compose.yml -f docker-compose.dev.yml up -d",
    "docker:rebuild": "docker compose -f docker-compose.yml -f docker-compose.dev.yml up -d --build",
    "docker:logs": "docker logs -f 20byte-web-1",
    "docker:ps": "docker compose -f docker-compose.yml -f docker-compose.dev.yml ps",
    "tunnel:vps": "bash scripts/tunnel-vps.sh",
    "vps:deploy": "ssh 20byte-vps 'cd /srv/20byte && ./scripts/deploy.sh'",
    "build": "next build",
    "start": "next start",
    "worker:start": "env -u DATABASE_URL -u REDIS_URL node scripts/run-with-local-env.mjs tsx worker/main.ts",
    "db:seed": "tsx scripts/seedDatabase.ts",
    "db:seed:ai-khun": "node scripts/run-with-local-env.mjs tsx scripts/seedAiAutomationForKhun.ts",
    "lint": "eslint .",
    "lint:campaign": "eslint components/whatsapp-campaigns/WhatsAppCampaignWorkspace.tsx app/api/whatsapp server/services/whatsappCampaignService.ts server/services/whatsappCampaignRules.ts server/services/message/baileysOutboundStatus.ts worker/processors/whatsappCampaignProcessor.ts",
    "typecheck": "tsc --noEmit --incremental false",
    "test": "NODE_ENV=test tsx --test tests/**/*.test.ts",
    "test:integration": "RUN_DB_INTEGRATION_TESTS=1 NODE_ENV=test tsx --test tests/integration/**/*.test.ts",
    "test:all": "RUN_DB_INTEGRATION_TESTS=1 NODE_ENV=test tsx --test tests/**/*.test.ts",
    "smoke:ui": "node scripts/smoke-ui.mjs",
    "smoke:ui:customers-deep": "node scripts/smoke-ui-customers-deep.mjs",
    "smoke:ui:inbox-deep": "node scripts/smoke-ui-inbox-deep.mjs",
    "smoke:ui:shortlinks-deep": "node scripts/smoke-ui-shortlinks-deep.mjs",
    "smoke:ui:pipeline-deep": "node scripts/smoke-ui-pipeline-deep.mjs",
    "smoke:ui:invoices-deep": "node scripts/smoke-ui-invoices-deep.mjs",
    "smoke:ui:report-campaign": "node scripts/smoke-ui-report-campaign.mjs",
    "smoke:ui:full": "npm run smoke:ui && npm run smoke:ui:customers-deep && npm run smoke:ui:inbox-deep && npm run smoke:ui:shortlinks-deep && npm run smoke:ui:pipeline-deep && npm run smoke:ui:invoices-deep",
    "smoke:ui:report": "node scripts/smoke-report-summary.mjs",
    "smoke:ui:full:report": "npm run smoke:ui:full && npm run smoke:ui:report",
    "audit:cross-org-write-coverage": "node scripts/audit-cross-org-write-coverage.mjs",
    "audit:fetch-latency": "node scripts/audit-fetch-latency.mjs",
    "quality:check": "npm run lint && npm run typecheck && npm test && npm run audit:cross-org-write-coverage",
    "quality:check:production": "npm run lint && npm run typecheck && npm run build && npm run test:all && npm run audit:cross-org-write-coverage && npm audit --omit=dev"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1024.0",
    "@fontsource/space-grotesk": "^5.2.10",
    "@hookform/resolvers": "^5.2.2",
    "@playwright/test": "^1.58.2",
    "@prisma/client": "^6.19.3",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-aspect-ratio": "^1.1.8",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-menubar": "^1.1.16",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.15",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-table": "^8.21.3",
    "@types/pdfkit": "^0.17.5",
    "ably": "^2.19.0",
    "baileys": "^7.0.0-rc.9",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "embla-carousel-react": "^8.6.0",
    "emoji-picker-react": "^4.18.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^0.469.0",
    "next": "15.5.14",
    "next-themes": "^0.4.6",
    "pdfkit": "^0.17.2",
    "qrcode": "^1.5.4",
    "react": "18.3.1",
    "react-day-picker": "^9.14.0",
    "react-dom": "18.3.1",
    "react-hook-form": "^7.71.2",
    "react-resizable-panels": "^4.7.3",
    "recharts": "^2.15.4",
    "sonner": "^2.0.7",
    "tailwind-merge": "^2.6.0",
    "vaul": "^1.1.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^8.57.1",
    "@types/node": "^22.10.2",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^18.3.16",
    "@types/react-dom": "^18.3.5",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "15.5.14",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-react": "^7.37.5",
    "globals": "^17.6.0",
    "jiti": "^2.7.0",
    "postcss": "^8.4.49",
    "prettier": "^3.4.2",
    "prisma": "^6.19.3",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.20.4",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.59.2"
  },
  "overrides": {
    "defu": "^6.1.6",
    "lodash": "^4.18.1",
    "fast-xml-parser": "^5.5.10"
  }
}
