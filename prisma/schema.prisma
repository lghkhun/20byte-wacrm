generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  OWNER
  ADMIN
  CS
  ADVERTISER
}

enum ConversationStatus {
  OPEN
  CLOSED
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum MessageType {
  TEXT
  IMAGE
  VIDEO
  AUDIO
  DOCUMENT
  TEMPLATE
  SYSTEM
}

enum MessageSendStatus {
  PENDING
  SENT
  FAILED
}

enum MessageDeliveryStatus {
  SENT
  DELIVERED
  READ
}

enum InvoiceStatus {
  DRAFT
  SENT
  PARTIALLY_PAID
  PAID
  VOID
}

enum InvoiceKind {
  FULL
  DP_AND_FINAL
}

enum PaymentMilestoneType {
  FULL
  DP
  FINAL
}

enum ProofType {
  TRANSFER
}

enum WaTemplateCategory {
  MARKETING
  UTILITY
  AUTHENTICATION
  SERVICE
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
}

enum BillingChargeStatus {
  PENDING
  PAID
  EXPIRED
  CANCELED
  FAILED
}

enum InvoiceGatewayFeePolicy {
  MERCHANT
  CUSTOMER
}

enum InvoicePaymentAttemptStatus {
  PENDING
  PAID
  EXPIRED
  CANCELED
  FAILED
  SUPERSEDED
}

enum WalletLedgerType {
  TOPUP_CREDIT
  WITHDRAW_DEBIT
  WITHDRAW_REFUND
  INVOICE_FEE_DEBIT
}

enum WalletLedgerDirection {
  CREDIT
  DEBIT
}

enum WalletTopupStatus {
  PENDING
  PAID
  EXPIRED
  CANCELED
  FAILED
}

enum WalletWithdrawStatus {
  PENDING
  APPROVED
  PAID
  REJECTED
  CANCELED
}

enum WhatsAppPublicScheduleStatus {
  PENDING
  SENT
  FAILED
  CANCELED
}

enum AccountSetupTokenPurpose {
  SET_PASSWORD
}

enum PlatformRole {
  SUPERADMIN
}

enum PlatformCouponDiscountType {
  FIXED
  PERCENT
}

enum PlatformCouponTarget {
  BILLING
  BUSINESS_PROVISIONING
  ALL
}

enum AiAgentRole {
  SALES_ASSISTANT
  CUSTOMER_SUPPORT
  ADMIN_ASSISTANT
  CUSTOM
}

enum AiAgentGoal {
  ANSWER_QUESTION
  COLLECT_LEAD
  PUSH_TO_BUY
  CLOSE_DEAL
}

enum AiTone {
  FRIENDLY
  CASUAL
  PROFESSIONAL
  PERSUASIVE
}

enum AiSalesMode {
  SOFT_SELLING
  HARD_SELLING
  INFORMATIVE
}

enum AiKnowledgeType {
  PRODUCT
  FAQ
  SOP
  OBJECTION_HANDLING
  CUSTOM
}

enum AiAutomationTrigger {
  CHAT_INCOMING
  NO_REPLY
  INVOICE_CREATED
  INVOICE_UNPAID
  TAG_ADDED
}

enum AiAutomationConditionType {
  CUSTOMER_TAG
  INVOICE_STATUS
  CONVERSATION_STATUS
  NO_HUMAN_REPLY
}

enum AiAutomationActionType {
  SEND_MESSAGE
  SEND_AI_REPLY
  STOP_AI_REPLY
  SEND_INVOICE
  ASSIGN_CS
  NOTIFY_CS
}

enum AiUsageType {
  AUTO_REPLY
  SUGGESTED_REPLY
  KNOWLEDGE_TEST
  AUTOMATION
}

enum AiProvider {
  OPENROUTER
}

enum WhatsAppFlowStatus {
  DRAFT
  ACTIVE
  PAUSED
  ARCHIVED
}

enum WhatsAppFlowTriggerType {
  MANUAL
  CHAT_INCOMING
}

enum WhatsAppFlowNodeType {
  SEND_TEMPLATE
  SEND_TEXT
  DELAY
  STOP
}

enum WhatsAppEnrollmentStatus {
  ACTIVE
  COMPLETED
  STOPPED
  FAILED
}

enum WhatsAppExecutionStatus {
  QUEUED
  SENT
  FAILED
  SKIPPED
  STOPPED
}

enum WhatsAppExecutionStopReason {
  FLOW_COMPLETED
  MANUAL_STOP
  TEMPLATE_ONLY_ENFORCED
  ENROLLMENT_NOT_ACTIVE
  CONVERSATION_NOT_FOUND
  SEND_FAILED
}

enum WhatsAppBroadcastStatus {
  DRAFT
  RUNNING
  COMPLETED
  CANCELED
}

enum WhatsAppBroadcastRecipientStatus {
  PENDING
  QUEUED
  SENT
  FAILED
  SKIPPED
  STOPPED
}

model Org {
  id                  String   @id @default(cuid())
  name                String
  legalName           String?
  responsibleName     String?
  businessPhone       String?
  businessEmail       String?
  businessNpwp        String?
  businessAddress     String?  @db.Text
  logoUrl             String?
  invoiceSignatureUrl String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  // Future wallet placeholder (Phase 2+), keep for forward compatibility
  walletBalanceCents Int @default(0)

  members                     OrgMember[]
  customers                   Customer[]
  customerTags                CustomerTag[]
  customerNotes               CustomerNote[]
  conversations               Conversation[]
  messages                    Message[]
  invoices                    Invoice[]
  invoiceItems                InvoiceItem[]
  paymentMilestones           PaymentMilestone[]
  paymentProofs               PaymentProof[]
  invoiceSequences            InvoiceSequence[]
  tags                        Tag[]
  serviceCatalogItems         ServiceCatalogItem[]
  waAccounts                  WaAccount[]
  shortlinks                  Shortlink[]
  shortlinkClicks             ShortlinkClick[]
  metaIntegrations            MetaIntegration[]
  metaEventDispatches         MetaEventDispatch[]
  auditLogs                   AuditLog[]
  setupTokens                 AccountSetupToken[]
  subscription                OrgSubscription?
  billingCharges              BillingCharge[]
  plan                        OrgPlan?
  bankAccounts                OrgBankAccount[]
  crmPipelines                CrmPipeline[]
  crmPipelineStages           CrmPipelineStage[]
  invoicePaymentSetting       OrgInvoicePaymentSetting?
  invoicePaymentAttempts      InvoicePaymentAttempt[]
  walletTopups                OrgWalletTopup[]
  walletLedgers               OrgWalletLedger[]
  walletWithdrawRequests      OrgWalletWithdrawRequest[]
  provisioningOrders          OwnerBusinessProvisioningOrder[]
  whatsappApiKey              OrgWhatsAppApiKey?
  whatsappPublicWebhook       OrgWhatsAppPublicWebhook?
  whatsappPublicSchedules     OrgWhatsAppPublicSchedule[]
  whatsappPublicWebhookEvents OrgWhatsAppPublicWebhookEvent[]
  aiAgentConfig               AiAgentConfig?
  aiKnowledge                 AiKnowledge[]
  aiAutomations               AiAutomation[]
  aiTokenBalance              AiTokenBalance?
  aiUsages                    AiUsage[]
  aiResponseLogs              AiResponseLog[]
  whatsappFlows               WhatsAppFlow[]
  whatsappFlowNodes           WhatsAppFlowNode[]
  whatsappFlowEdges           WhatsAppFlowEdge[]
  whatsappFlowRules           WhatsAppFlowRule[]
  whatsappEnrollments         WhatsAppEnrollment[]
  whatsappExecutions          WhatsAppExecution[]
  whatsappComplianceEvents    WhatsAppComplianceEvent[]
  whatsappSuppressions        WhatsAppSuppression[]
  whatsappBroadcasts          WhatsAppBroadcast[]
  whatsappBroadcastRecipients WhatsAppBroadcastRecipient[]
  whatsappRulePendingChecks   WhatsAppRulePendingCheck[]

  @@index([createdAt])
}

model OrgPlan {
  id             String   @id @default(cuid())
  orgId          String   @unique
  planKey        String // starter | growth | pro
  seatLimit      Int
  storageQuotaMb Int
  retentionDays  Int
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  org Org @relation(fields: [orgId], references: [id])
}

model OrgMember {
  id        String   @id @default(cuid())
  orgId     String
  userId    String
  role      Role
  createdAt DateTime @default(now())

  org                   Org            @relation(fields: [orgId], references: [id])
  user                  User           @relation(fields: [userId], references: [id])
  assignedConversations Conversation[] @relation("AssignedConversations")

  @@unique([orgId, userId])
  @@index([orgId, role])
}

model User {
  id                        String    @id @default(cuid())
  email                     String    @unique
  phoneE164                 String?   @unique
  passwordHash              String?
  passwordSetAt             DateTime?
  securityNoticeDismissedAt DateTime?
  isSuspended               Boolean   @default(false)
  name                      String?
  avatarUrl                 String?
  createdAt                 DateTime  @default(now())
  updatedAt                 DateTime  @updatedAt

  memberships                    OrgMember[]
  setupTokens                    AccountSetupToken[]
  platformMembership             PlatformMember?
  provisioningOrders             OwnerBusinessProvisioningOrder[]
  createdWhatsAppApiKeys         OrgWhatsAppApiKey[]
  createdWhatsAppPublicSchedules OrgWhatsAppPublicSchedule[]
  createdWhatsAppFlows           WhatsAppFlow[]
  createdWhatsAppEnrollments     WhatsAppEnrollment[]
  createdWhatsAppBroadcasts      WhatsAppBroadcast[]
  createdWhatsAppFlowRules       WhatsAppFlowRule[]

  @@index([phoneE164])
}

model OrgBankAccount {
  id            String   @id @default(cuid())
  orgId         String
  bankName      String
  accountNumber String
  accountHolder String
  createdAt     DateTime @default(now())

  org Org @relation(fields: [orgId], references: [id])

  @@index([orgId])
}

model WaAccount {
  id             String   @id @default(cuid())
  orgId          String
  metaBusinessId String
  wabaId         String
  phoneNumberId  String
  displayPhone   String
  createdAt      DateTime @default(now())
  connectedAt    DateTime @default(now())

  // Store encrypted token only
  accessTokenEnc String

  org Org @relation(fields: [orgId], references: [id])

  @@unique([orgId])
  @@unique([orgId, phoneNumberId])
  @@unique([phoneNumberId])
  @@index([orgId])
}

model Customer {
  id                 String    @id @default(cuid())
  orgId              String
  phoneE164          String
  displayName        String?
  waProfilePicUrl    String?
  leadStatus         String    @default("NEW_LEAD")
  followUpStatus     String?
  followUpAt         DateTime?
  businessCategory   String?
  detail             String?
  hotness            String    @default("COLD")
  packageName        String?
  projectValueCents  Int?
  remarks            String?   @db.Text
  assignedToMemberId String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  // Attribution (persisted on customer)
  source         String? // organic | meta_ads | etc
  campaign       String?
  adset          String?
  ad             String?
  platform       String?
  medium         String?
  firstContactAt DateTime?

  org            Org             @relation(fields: [orgId], references: [id])
  conversations  Conversation[]
  invoices       Invoice[]
  notes          CustomerNote[]
  tagLinks       CustomerTag[]
  aiUsages       AiUsage[]
  aiResponseLogs AiResponseLog[]
  whatsappEnrollments WhatsAppEnrollment[]
  whatsappSuppressions WhatsAppSuppression[]
  whatsappBroadcastRecipients WhatsAppBroadcastRecipient[]
  whatsappRulePendingChecks WhatsAppRulePendingCheck[]

  @@unique([orgId, phoneE164])
  @@index([orgId])
  @@index([orgId, createdAt])
  @@index([orgId, updatedAt])
  @@index([orgId, displayName])
  @@index([orgId, leadStatus, firstContactAt])
  @@index([orgId, hotness, firstContactAt])
  @@index([orgId, assignedToMemberId, firstContactAt])
  @@index([orgId, source, firstContactAt])
  @@index([orgId, followUpAt])
  @@index([orgId, firstContactAt, createdAt], map: "cust_org_firstcontact_created_idx")
}

model Tag {
  id        String   @id @default(cuid())
  orgId     String
  name      String
  color     String // e.g. "emerald", "purple", "amber"
  createdAt DateTime @default(now())

  org           Org           @relation(fields: [orgId], references: [id])
  customerLinks CustomerTag[]

  @@unique([orgId, name])
  @@index([orgId])
}

model CustomerTag {
  id         String   @id @default(cuid())
  orgId      String
  customerId String
  tagId      String
  createdAt  DateTime @default(now())

  org      Org      @relation(fields: [orgId], references: [id])
  customer Customer @relation(fields: [customerId], references: [id])
  tag      Tag      @relation(fields: [tagId], references: [id])

  @@unique([customerId, tagId])
  @@index([orgId])
  @@index([customerId])
}

model CustomerNote {
  id           String   @id @default(cuid())
  orgId        String
  customerId   String
  authorUserId String
  content      String
  createdAt    DateTime @default(now())

  org      Org      @relation(fields: [orgId], references: [id])
  customer Customer @relation(fields: [customerId], references: [id])

  @@index([customerId, createdAt])
  @@index([orgId, createdAt])
}

model Conversation {
  id         String             @id @default(cuid())
  orgId      String
  customerId String
  status     ConversationStatus @default(OPEN)

  assignedToMemberId    String? // OrgMember.id
  assignedToMember      OrgMember? @relation("AssignedConversations", fields: [assignedToMemberId], references: [id])
  lastMessageSenderName String?
  lastMessageAt         DateTime?
  unreadCount           Int        @default(0)

  // Attribution (copied for conversation-level analytics)
  sourceCampaign        String?
  sourcePlatform        String?
  sourceMedium          String?
  shortlinkId           String?
  trackingId            String?
  fbclid                String?
  fbc                   String?
  fbp                   String?
  ctwaClid              String?
  wabaId                String?
  waChatJid             String?
  groupParticipantsJson String? @db.LongText
  crmPipelineId         String?
  crmStageId            String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  org            Org               @relation(fields: [orgId], references: [id])
  customer       Customer          @relation(fields: [customerId], references: [id])
  crmPipeline    CrmPipeline?      @relation(fields: [crmPipelineId], references: [id])
  crmStage       CrmPipelineStage? @relation(fields: [crmStageId], references: [id])
  messages       Message[]
  invoices       Invoice[]
  aiUsages       AiUsage[]
  aiResponseLogs AiResponseLog[]
  whatsappEnrollments WhatsAppEnrollment[]
  whatsappSuppressions WhatsAppSuppression[]
  whatsappBroadcastRecipients WhatsAppBroadcastRecipient[]
  whatsappRulePendingChecks WhatsAppRulePendingCheck[]

  @@index([orgId, status, lastMessageAt])
  @@index([orgId, status, lastMessageAt, updatedAt], map: "conv_org_status_lastmsg_upd_idx")
  @@index([orgId, status, crmPipelineId, lastMessageAt, updatedAt], map: "conv_org_status_pipe_last_upd_idx")
  @@index([orgId, assignedToMemberId, lastMessageAt])
  @@index([orgId, assignedToMemberId, status, lastMessageAt, updatedAt], map: "conv_org_assignee_status_lastmsg_upd_idx")
  @@index([orgId, assignedToMemberId, status, crmPipelineId, lastMessageAt, updatedAt], map: "conv_org_asg_st_pipe_last_upd_idx")
  @@index([customerId])
  @@index([orgId, waChatJid], map: "conv_org_wa_chat_jid_idx")
  @@index([trackingId])
  @@index([ctwaClid])
  @@index([crmPipelineId])
  @@index([crmStageId])
}

model CrmPipeline {
  id        String   @id @default(cuid())
  orgId     String
  name      String
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  org           Org                @relation(fields: [orgId], references: [id])
  stages        CrmPipelineStage[]
  conversations Conversation[]

  @@unique([orgId, name])
  @@index([orgId, createdAt])
}

model CrmPipelineStage {
  id         String   @id @default(cuid())
  orgId      String
  pipelineId String
  name       String
  color      String   @default("emerald")
  position   Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  org           Org            @relation(fields: [orgId], references: [id])
  pipeline      CrmPipeline    @relation(fields: [pipelineId], references: [id])
  conversations Conversation[]

  @@unique([pipelineId, name])
  @@index([orgId, pipelineId, position])
}

model Message {
  id             String  @id @default(cuid())
  orgId          String
  conversationId String
  waMessageId    String? @unique

  direction MessageDirection
  type      MessageType
  text      String?          @db.LongText

  // Media metadata
  mediaId     String? // WhatsApp media ID (for retrieval)
  mediaUrl    String? // R2 public or signed URL
  mimeType    String?
  fileName    String?
  fileSize    Int?
  durationSec Int?

  // Template metadata
  templateName           String?
  templateCategory       WaTemplateCategory?
  templateLanguageCode   String?
  templateComponentsJson String?

  // System metadata
  isAutomated       Boolean                @default(false)
  sendStatus        MessageSendStatus?
  deliveryStatus    MessageDeliveryStatus?
  sendError         String?
  sendAttemptCount  Int                    @default(0)
  lastSendAttemptAt DateTime?
  deliveredAt       DateTime?
  readAt            DateTime?
  retryable         Boolean                @default(false)

  // Reply metadata (WhatsApp quoted message context)
  replyToMessageId       String?
  replyToWaMessageId     String?
  replyPreviewText       String?
  replyPreviewSenderName String?

  // Sender metadata (important for group chats)
  senderWaJid       String?
  senderPhoneE164   String?
  senderDisplayName String?

  createdAt DateTime @default(now())

  org           Org            @relation(fields: [orgId], references: [id])
  conversation  Conversation   @relation(fields: [conversationId], references: [id])
  paymentProofs PaymentProof[]
  whatsappExecutions WhatsAppExecution[]
  whatsappBroadcastRecipients WhatsAppBroadcastRecipient[]
  whatsappRulePendingChecks WhatsAppRulePendingCheck[]

  @@index([conversationId, createdAt])
  @@index([orgId, conversationId, createdAt], map: "msg_org_conv_created_idx")
  @@index([orgId, createdAt])
  @@index([orgId, conversationId, replyToMessageId, createdAt], map: "msg_org_conv_reply_created_idx")
}

model ServiceCatalogItem {
  id         String  @id @default(cuid())
  orgId      String
  name       String
  category   String?
  unit       String?
  priceCents Int?
  currency   String  @default("IDR")

  // Allowed attachments: image/pdf/link (no video)
  attachmentUrl  String?
  attachmentType String? // "image" | "pdf" | "link"

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  org Org @relation(fields: [orgId], references: [id])

  @@index([orgId, createdAt])
}

model Invoice {
  id                          String  @id @default(cuid())
  orgId                       String
  customerId                  String
  conversationId              String?
  customerDisplayNameSnapshot String?

  invoiceNo String
  kind      InvoiceKind
  status    InvoiceStatus @default(DRAFT)

  currency             String @default("IDR")
  grossSubtotalCents   Int    @default(0)
  lineDiscountCents    Int    @default(0)
  invoiceDiscountType  String @default("%")
  invoiceDiscountValue Int    @default(0)
  invoiceDiscountCents Int    @default(0)
  taxCents             Int    @default(0)
  subtotalCents        Int    @default(0)
  totalCents           Int    @default(0)

  // Optional due date (per invoice overall)
  dueDate DateTime?

  // Public access token
  publicToken String @unique

  // Snapshot of bank accounts for invoice rendering (stable even if org settings change later)
  bankAccountsJson String @db.LongText

  // PDF stored on R2
  pdfUrl String?
  notes  String? @db.LongText
  terms  String? @db.LongText

  createdByUserId String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  org          Org           @relation(fields: [orgId], references: [id])
  customer     Customer      @relation(fields: [customerId], references: [id])
  conversation Conversation? @relation(fields: [conversationId], references: [id])

  items           InvoiceItem[]
  milestones      PaymentMilestone[]
  proofs          PaymentProof[]
  paymentAttempts InvoicePaymentAttempt[]

  @@unique([orgId, invoiceNo])
  @@index([orgId, customerId, createdAt])
  @@index([conversationId])
  @@index([orgId, conversationId, createdAt], map: "inv_org_conv_created_idx")
}

model OrgInvoicePaymentSetting {
  id                      String                  @id @default(cuid())
  orgId                   String                  @unique
  enableBankTransfer      Boolean                 @default(true)
  enableQris              Boolean                 @default(false)
  enabledVaMethodsJson    String                  @db.LongText
  feePolicy               InvoiceGatewayFeePolicy @default(CUSTOMER)
  autoConfirmLabelEnabled Boolean                 @default(true)
  paymentMethodsOrderJson String?                 @db.LongText
  createdAt               DateTime                @default(now())
  updatedAt               DateTime                @updatedAt

  org Org @relation(fields: [orgId], references: [id])
}

model InvoicePaymentAttempt {
  id                   String                      @id @default(cuid())
  orgId                String
  invoiceId            String
  orderId              String                      @unique
  provider             String                      @default("pakasir")
  paymentMethod        String
  feePolicy            InvoiceGatewayFeePolicy
  invoiceAmountCents   Int
  feeCents             Int                         @default(0)
  customerPayableCents Int
  status               InvoicePaymentAttemptStatus @default(PENDING)
  paymentNumber        String?                     @db.LongText
  expiresAt            DateTime?
  paidAt               DateTime?
  gatewayRawJson       String?                     @db.LongText
  createdAt            DateTime                    @default(now())
  updatedAt            DateTime                    @updatedAt

  org     Org     @relation(fields: [orgId], references: [id])
  invoice Invoice @relation(fields: [invoiceId], references: [id])

  @@index([orgId, invoiceId, createdAt])
  @@index([orgId, status, createdAt])
}

model InvoiceItem {
  id            String   @id @default(cuid())
  orgId         String
  invoiceId     String
  name          String
  description   String?
  qty           Int      @default(1)
  unit          String?
  priceCents    Int
  subtotalCents Int      @default(0)
  discountType  String   @default("IDR")
  discountValue Int      @default(0)
  discountCents Int      @default(0)
  taxLabel      String?
  taxRateBps    Int      @default(0)
  taxCents      Int      @default(0)
  amountCents   Int
  createdAt     DateTime @default(now())

  org     Org     @relation(fields: [orgId], references: [id])
  invoice Invoice @relation(fields: [invoiceId], references: [id])

  @@index([orgId, invoiceId])
  @@index([invoiceId])
}

model PaymentMilestone {
  id          String               @id @default(cuid())
  orgId       String
  invoiceId   String
  type        PaymentMilestoneType
  amountCents Int
  dueDate     DateTime?
  status      String // "PENDING" | "PAID"
  paidAt      DateTime?
  createdAt   DateTime             @default(now())

  org     Org     @relation(fields: [orgId], references: [id])
  invoice Invoice @relation(fields: [invoiceId], references: [id])

  @@unique([invoiceId, type])
  @@index([orgId, invoiceId])
  @@index([orgId, status, paidAt], map: "pm_org_status_paidat_idx")
  @@index([invoiceId])
}

model PaymentProof {
  id            String                @id @default(cuid())
  orgId         String
  invoiceId     String
  milestoneType PaymentMilestoneType? // optional: proof can attach to specific milestone
  type          ProofType             @default(TRANSFER)

  // Link to original chat message (recommended)
  messageId String?
  mediaUrl  String
  mimeType  String?
  fileSize  Int?

  createdByUserId String
  createdAt       DateTime @default(now())

  org     Org      @relation(fields: [orgId], references: [id])
  invoice Invoice  @relation(fields: [invoiceId], references: [id])
  message Message? @relation(fields: [messageId], references: [id])

  @@index([invoiceId, createdAt])
  @@index([orgId, createdAt])
  @@index([messageId])
}

model InvoiceSequence {
  id        String   @id @default(cuid())
  orgId     String
  year      Int
  lastSeq   Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  org Org @relation(fields: [orgId], references: [id])

  @@unique([orgId, year])
  @@index([orgId, year])
}

model AiAgentConfig {
  id                  String      @id @default(cuid())
  orgId               String      @unique
  enabled             Boolean     @default(false)
  role                AiAgentRole @default(SALES_ASSISTANT)
  goal                AiAgentGoal @default(ANSWER_QUESTION)
  tone                AiTone      @default(FRIENDLY)
  salesMode           AiSalesMode @default(SOFT_SELLING)
  businessName        String?
  advancedPrompt      String?     @db.Text
  stopIfHumanReply    Boolean     @default(true)
  typingDelayMs       Int         @default(1200)
  multiBubbleReply    Boolean     @default(false)
  confidenceThreshold Int         @default(70)
  provider            AiProvider  @default(OPENROUTER)
  modelFree           String      @default("meta-llama/llama-3.1-8b-instruct:free")
  modelPaid           String      @default("anthropic/claude-3-haiku")
  activeModelTier     String      @default("FREE")
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt

  org Org @relation(fields: [orgId], references: [id])

  @@index([orgId])
}

model AiKnowledge {
  id        String          @id @default(cuid())
  orgId     String
  type      AiKnowledgeType
  title     String
  content   String          @db.Text
  question  String?         @db.Text
  answer    String?         @db.Text
